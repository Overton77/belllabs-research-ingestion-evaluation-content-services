# PRE-EMPTIVE SETUP: copy only missing names into .env; never commit real values.
DATABASE_DIRECT=
DATABASE_URL=
# Application-owned run-control PostgreSQL. Never point this at Temporal persistence.
APPLICATION_DATABASE_DIRECT=postgresql://belllabs_app:belllabs-app-local@127.0.0.1:55432/belllabs
APPLICATION_DATABASE_URL=
# Production uses a distinct schema-owner credential for migrations.
APPLICATION_MIGRATION_DATABASE_DIRECT=postgresql://belllabs:belllabs-local@127.0.0.1:55432/belllabs
APPLICATION_POSTGRES_PORT=55432
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano
MONGODB_URI=
MONGODB_DATABASE=belllabsbiotech
# Host-mapped away from 6379 to avoid WSL/local Redis collisions (mirrors APPLICATION_POSTGRES_PORT).
REDIS_PORT=56379
REDIS_URL=redis://localhost:56379/0
RUNTIME_REALTIME_REQUIRED=false
RUNTIME_APPROVAL_TIMEOUT_SECONDS=900
RUNTIME_CHECKPOINT_SIGNING_KEY=
NEO4J_URI=
NEO4J_AURA_USERNAME=
NEO4J_AURA_PASSWORD=
AWS_REGION=us-east-1
AWS_PROFILE=default
S3_BUCKET=
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=biotech-research-ingestion
SANDBOX_IMAGE=python:3.12-slim
API_HOST=127.0.0.1
API_PORT=8000
SOCKETIO_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
